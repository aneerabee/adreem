NODE_ENV=production
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=keep-this-only-on-the-server
ADREEM_WEB_ALLOWED_ORIGIN=https://aneerabee.github.io
# Prefer hashed tokens on the server. Generate with:
# node -e "const {createHash}=require('crypto'); console.log(createHash('sha256').update('replace-with-long-random-token').digest('hex'))"
ADREEM_WEB_LEDGER_TOKEN_HASHES=replace-with-sha256-token-hash=main
# Temporary compatibility only. Do not use for new ledgers.
# ADREEM_WEB_LEDGER_TOKENS=replace-with-long-random-token=main
# Optional server-only token used by npm run verify:runtime to test /api/ledger.
ADREEM_RUNTIME_TEST_TOKEN=replace-with-long-random-token
ADREEM_API_PORT=8787
TELEGRAM_BOT_TOKEN=replace-with-telegram-token
ADREEM_TELEGRAM_USER_IDS=your-telegram-user-id
ADREEM_TELEGRAM_ADMIN_IDS=your-telegram-user-id
ADREEM_TELEGRAM_LEDGER_IDS=your-telegram-user-id=main
ADREEM_TELEGRAM_USERS_FILE=/home/argaz/apps/adreem/adreem-telegram-users.json
TELEGRAM_SKIP_OLD_UPDATES=true
